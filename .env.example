# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Twitter (X) API keys for OAuth and verification
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_KEY_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_APP_CALLBACK_URL=https://your-vercel-app.vercel.app/auth/twitter/callback

# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/buzzlayer?retryWrites=true&w=majority

# JWT secret for session management
JWT_SECRET=your_secure_jwt_secret_here

# Optional payment wallet (for token/USDT payouts)
WALLET_ADDRESS=0x0000000000000000000000000000000000000000